{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "panshi-formwork",
  "compatibility_date": "2026-04-30",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "panshi-formwork.com/*", "zone_name": "panshi-formwork.com" },
    { "pattern": "www.panshi-formwork.com/*", "zone_name": "panshi-formwork.com" }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
