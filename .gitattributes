# 預設用 LF 換行，避免 Windows / Mac / Cloudflare CI 之間 CRLF 衝突
* text=auto eol=lf

# PowerShell 腳本必須用 CRLF，否則 Windows 執行會出錯
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# 二進位檔不要當文字處理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp4 binary
*.zip binary
